rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isValidId(productId);
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(request.resource.data);
      allow get: if isValidId(orderId);
      allow list, update: if true;
      allow delete: if true; // Allow delete for archiving in this standalone app
    }

    // System Config Collection (for Admin Password)
    match /system_config/{configId} {
      allow get, create, update, list: if isValidId(configId);
      allow delete: if false;
    }

    // Global Validation Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customerName', 'customerPhone', 'items', 'totalPrice', 'status', 'notes', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.id is string
        && data.customerName is string
        && data.customerName.size() >= 1
        && data.customerName.size() <= 100
        && data.customerPhone is string
        && data.customerPhone.size() >= 1
        && data.customerPhone.size() <= 24
        && data.totalPrice is number
        && data.totalPrice >= 0
        && data.status in ['pending', 'preparing', 'completed', 'cancelled']
        && data.notes is string
        && data.notes.size() <= 1000;
    }
  }
}
